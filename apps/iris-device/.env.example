# Copy to the device state directory as `.env`.

IRIS_API_URL=http://127.0.0.1:4747

# Optional: if unset, `device_client.py claim <pairing-token>` stores the token
# in `.device-token` with owner-only permissions.
IRIS_DEVICE_TOKEN=

# Optional. If empty, the device derives `IRIS-DEV-<hardware-id>`.
IRIS_DEVICE_SERIAL=
# Optional. If empty, the device reports the current local release version.
IRIS_DEVICE_FIRMWARE_VERSION=
IRIS_DEVICE_SETUP_NAME=Device 1

# User/group that runs the audio service. BLE setup runs as root and chowns
# claimed device identity files so this service can read them.
IRIS_DEVICE_SERVICE_USER=pi
IRIS_DEVICE_SERVICE_GROUP=audio

# ALSA capture settings. The device publishes pcm16 frames to the Iris voice.
IRIS_DEVICE_SAMPLE_RATE=16000
IRIS_DEVICE_CHANNELS=2
# Optional zero-based channel selector for multi-channel capture devices. For the
# XVF3800 2-channel USB firmware, channel 0 is the conference/processed output
# and channel 1 is the hotter AEC residual output on the current firmware.
# Channel 0 is the STT feed because it preserves user speech while suppressing
# Iris playback echo better on the physical ReSpeaker XVF3800 path.
# Verify with `xvf_host AUDIO_MGR_OP_L AUDIO_MGR_OP_R` after firmware changes.
IRIS_DEVICE_CAPTURE_CHANNEL_INDEX=0
# Optional channel override only while Iris playback is active. The XVF3800
# residual channel is hotter for near speech during speaker playback on the
# current firmware, so use it for wake-word interruption while keeping channel 0
# for normal STT.
IRIS_DEVICE_PLAYBACK_CAPTURE_CHANNEL_INDEX=1
IRIS_DEVICE_CHUNK_MS=100

# Optional ALSA device, for example `hw:1,0`.
IRIS_DEVICE_ALSA_DEVICE=plughw:CARD=Array,DEV=0
# Optional ALSA capture gain applied at service startup, for example `100%`.
IRIS_DEVICE_ALSA_CAPTURE_VOLUME=
# Optional ALSA playback device, for example `plughw:CARD=Device_1,DEV=0`.
IRIS_DEVICE_PLAYBACK_DEVICE=plughw:CARD=Array,DEV=0
# XVF3800 playback is audible on the stereo path; mono may only feed an internal
# reference path.
IRIS_DEVICE_PLAYBACK_CHANNELS=2
# Play short local earcons for wake detection, speaker identity, and tool starts.
IRIS_DEVICE_EARCONS_ENABLED=true
# Optional wake-only control. The legacy wake-word chime flag is still respected
# for wake cues, but does not disable tool or speaker-identity cues.
IRIS_DEVICE_WAKE_EARCON_ENABLED=true
IRIS_DEVICE_WAKE_WORD_CHIME_ENABLED=true
# Keep playback open across normal streaming gaps so short TTS pauses do not
# close and reopen ALSA mid-utterance.
IRIS_DEVICE_PLAYBACK_IDLE_STOP_SECONDS=6.0
# Optional ALSA timing overrides in microseconds.
IRIS_DEVICE_ALSA_BUFFER_TIME_US=500000
IRIS_DEVICE_ALSA_PERIOD_TIME_US=100000

IRIS_DEVICE_REPORT_INTERVAL_SECONDS=30

# Device voice runtime. `pipecat` streams continuously and wake-gates assistant speech.
IRIS_DEVICE_VOICE_RUNTIME=pipecat
