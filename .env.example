# Local Iris defaults.
IRIS_AUTH_MODE=local
IRIS_ENV=local

PORT=4747
IRIS_API_URL=http://127.0.0.1:4747
IRIS_VOICE_URL=http://127.0.0.1:4748
IRIS_VOICE_PORT=4748
IRIS_SPEAKER_ID_URL=http://127.0.0.1:4749
IRIS_SPEAKER_ID_PORT=4749
IRIS_SOUND_RECOGNITION_URL=http://127.0.0.1:4751
IRIS_SOUND_RECOGNITION_PORT=4751
IRIS_SOUND_RECOGNITION_ENABLED=false

# Local SQLite database.
IRIS_SQLITE_PATH=.iris/iris.sqlite
IRIS_RUN_MIGRATIONS=true

# Local profile used when auth is disabled.
IRIS_LOCAL_USER_ID=user_local
IRIS_LOCAL_USER_EMAIL=local@iris.local
IRIS_LOCAL_USER_NAME=Iris
IRIS_ORGANIZATION_ID=org_iris
IRIS_ORGANIZATION_NAME=Iris

# Shared local service secret. Change this outside throwaway development.
IRIS_TOKEN_SECRET=dev-token
IRIS_API_KEY=

# User-owned model, speech, and TTS keys.
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# Optional desktop/Codex bridge.
IRIS_HUB_BRIDGE_URL=http://127.0.0.1:8765/hub
IRIS_HUB_BRIDGE_TOKEN=
IRIS_HUB_ID=local-mac
